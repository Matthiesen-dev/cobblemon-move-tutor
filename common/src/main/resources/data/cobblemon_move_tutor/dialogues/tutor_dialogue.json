{
  "initializationAction": [
    "c.npc.set_chatting();",
    "v.slot1 = q.player.party.get_pokemon(0);",
    "v.slot2 = q.player.party.get_pokemon(1);",
    "v.slot3 = q.player.party.get_pokemon(2);",
    "v.slot4 = q.player.party.get_pokemon(3);",
    "v.slot5 = q.player.party.get_pokemon(4);",
    "v.slot6 = q.player.party.get_pokemon(5);"
  ],
  "speakers": {
    "npc": {
      "name": {
        "type": "expression",
        "expression": "q.npc.name"
      },
      "face": "q.npc.face();"
    },
    "player": {
      "face": "q.player.face();",
      "name": {
        "type": "expression",
        "expression": "q.player.username"
      }
    }
  },
  "pages": [
    {
      "id": "greeting",
      "speaker": "npc",
      "lines": [
        "Hello, I'm a move tutor! I can help teach your Pokemon new moves.",
        "Let's get started! Would you like to see the move tutor options?"
      ],
      "input": "q.dialogue.set_page('options');"
    },
    {
      "id": "options",
      "speaker": "npc",
      "lines": [
        "Select a Pokemon to teach a move to."
      ],
      "input": {
        "type": "option",
        "vertical": true,
        "options": [
          {
            "text": {
              "type": "expression",
              "expression": "v.slot1.species.name;"
            },
            "isVisible": "v.slot1 != 0",
            "value": "s1",
            "action": [
              "q.player.open_village_tutor(0);",
              "q.dialogue.close();"
            ]
          },
          {
            "text": {
              "type": "expression",
              "expression": "v.slot2.species.name;"
            },
            "isVisible": "v.slot2 != 0",
            "value": "s2",
            "action": [
              "q.player.open_village_tutor(1);",
              "q.dialogue.close();"
            ]
          },
          {
            "text": {
              "type": "expression",
              "expression": "v.slot3.species.name;"
            },
            "isVisible": "v.slot3 != 0",
            "value": "s3",
            "action": [
              "q.player.open_village_tutor(2);",
              "q.dialogue.close();"
            ]
          },
          {
            "text": {
              "type": "expression",
              "expression": "v.slot4.species.name;"
            },
            "isVisible": "v.slot4 != 0",
            "value": "s4",
            "action": [
              "q.player.open_village_tutor(3);",
              "q.dialogue.close();"
            ]
          },
          {
            "text": {
              "type": "expression",
              "expression": "v.slot5.species.name;"
            },
            "isVisible": "v.slot5 != 0",
            "value": "s5",
            "action": [
              "q.player.open_village_tutor(4);",
              "q.dialogue.close();"
            ]
          },
          {
            "text": {
              "type": "expression",
              "expression": "v.slot6.species.name;"
            },
            "isVisible": "v.slot6 != 0",
            "value": "s6",
            "action": [
              "q.player.open_village_tutor(5);",
              "q.dialogue.close();"
            ]
          },
          {
            "text": "§cCancel§r",
            "value": "no",
            "action": "q.dialogue.set_page('okbye');"
          }
        ]
      }
    },
    {
      "id": "okbye",
      "speaker": "npc",
      "lines": [
        "Alright, see you later!"
      ],
      "input": "q.dialogue.close();"
    }
  ]
}