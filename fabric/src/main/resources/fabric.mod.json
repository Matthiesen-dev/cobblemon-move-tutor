{
  "schemaVersion": 1,
  "id": "${mod_id}",
  "version": "${version}",
  "name": "${mod_name}",
  "description": "${mod_description}",
  "authors": [
    "${mod_author}"
  ],
  "license": "${mod_license}",
  "icon": "logo.png",
  "contact": {
    "homepage": "${github_url}",
    "sources": "${github_url}",
    "issues": "${github_url}/issues"
  },
  "custom": {
    "modmenu": {
      "links": {
        "modmenu.github_releases": "${github_url}",
        "modmenu.modrinth": "${modrinth_url}"
      }
    }
  },
  "environment": "*",
  "entrypoints": {
    "main": [
      "dev.matthiesen.fabric.cobblemon_move_tutor.CobblemonMoveTutorFabric"
    ],
    "client": [
      "dev.matthiesen.fabric.cobblemon_move_tutor.CobblemonMoveTutorFabricClient"
    ]
  },
  "depends": {
    "minecraft": "1.21.1",
    "cobblemon": ">=1.7.3 <1.8.0",
    "matthiesen_lib": ">=1.0.0 <2.0.0"
  }
}